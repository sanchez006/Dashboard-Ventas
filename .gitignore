# Ignore everything by default, then allow specific folders/files
/*

# Keep these repo files
!/.gitignore
!/README.md

# Keep backend and frontend directories and their contents
!/backend/
!/backend/**
!/frontend/
!/frontend/**

# Ignore Angular build/cache folders inside frontend
/frontend/.angular/
/frontend/.angular/**

# Ignore environment files with secrets in backend
/backend/.env

# Local editor and OS files (still ignored when outside allowed dirs)
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Python caches and envs (also ensure root .py files are ignored)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
*.egg-info/
dist/
build/

# Node artifacts
node_modules/
dist/
build/

# Misc
*.log
*.bak
*.tmp
.cache/

# If you want to allow other top-level files add them explicitly with !/filename
